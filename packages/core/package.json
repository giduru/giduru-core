{
  "name": "giduru-core",
  "version": "0.1.1",
  "description": "Pure hledger parsing and verification engine extracted from Giduru.",
  "keywords": [
    "giduru",
    "hledger",
    "ledger",
    "parser",
    "accounting"
  ],
  "license": "UNLICENSED",
  "homepage": "https://github.com/giduru/giduru-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giduru/giduru-core.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/giduru/giduru-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "ARTIFACTS.md",
    "ARCHITECTURE.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bench": "npm run build && node bench/run.js",
    "pack:dry-run": "npm_config_cache=.npm-cache npm pack --dry-run",
    "publish:check": "npm run typecheck && npm test && npm run pack:dry-run",
    "publish:public": "npm_config_cache=.npm-cache npm publish --access public",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile .tsconfig.typecheck.tsbuildinfo",
    "prepublishOnly": "npm run publish:check"
  },
  "dependencies": {
    "@lezer/common": "^1.5.1",
    "codemirror-lang-hledger": "^0.5.0"
  }
}
